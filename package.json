{
  "name": "lenso-site",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "build": "next build",
    "worker:build": "opennextjs-cloudflare build",
    "deploy": "pnpm worker:build && opennextjs-cloudflare deploy",
    "deploy:dry-run": "pnpm worker:build && wrangler deploy --dry-run",
    "dev": "next dev",
    "start": "opennextjs-cloudflare preview",
    "types:check": "fumadocs-mdx && next typegen && tsc --noEmit",
    "postinstall": "fumadocs-mdx",
    "lint": "eslint"
  },
  "dependencies": {
    "@opennextjs/cloudflare": "^1.19.11",
    "@orama/orama": "^3.1.18",
    "fumadocs-core": "16.10.4",
    "fumadocs-mdx": "15.0.12",
    "fumadocs-ui": "16.10.4",
    "gsap": "^3.15.0",
    "lucide-react": "^1.20.0",
    "next": "16.2.9",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tailwind-merge": "^3.6.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.1",
    "@types/mdx": "^2.0.14",
    "@types/node": "^25.9.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9.39.4",
    "eslint-config-next": "16.2.9",
    "postcss": "^8.5.15",
    "serve": "^14.2.6",
    "tailwindcss": "^4.3.1",
    "typescript": "^6.0.3",
    "wrangler": "^4.103.0"
  }
}
